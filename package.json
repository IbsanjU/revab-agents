{
  "name": "revab-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Centralized multi-agent QE automation framework: local MCP servers, async orchestrator, Playwright BDD, Allure.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"utils/*.test.ts\" \"orchestrator/*.test.ts\" \"scripts/*.test.ts\"",
    "check:conventions": "tsx scripts/check-conventions.ts",
    "build:prompts": "tsx scripts/build-prompts.ts",
    "knowledge:rotate": "tsx scripts/rotate-learnings.ts",
    "serve:jira": "tsx mcp-servers/jira/index.ts",
    "serve:confluence": "tsx mcp-servers/confluence/index.ts",
    "serve:jtmf": "tsx mcp-servers/jtmf/index.ts",
    "serve:artifacts": "tsx mcp-servers/artifacts/index.ts",
    "serve:media": "tsx mcp-servers/media/index.ts",
    "serve:github": "tsx mcp-servers/github/index.ts",
    "serve:git": "tsx mcp-servers/git/index.ts",
    "serve:playwright-runner": "tsx mcp-servers/playwright-runner/index.ts",
    "serve:allure-report": "tsx mcp-servers/allure-report/index.ts",
    "serve:codegen": "tsx mcp-servers/codegen/index.ts",
    "serve:playwright": "npx @playwright/mcp@latest --port 7315",
    "serve:mcp": "concurrently -n jira,conf,jtmf,art,media,gh,git,notify,pwr,allure,codegen,pw -c blue,green,yellow,magenta,cyan,white,white,red,white,gray,gray,gray npm:serve:jira npm:serve:confluence npm:serve:jtmf npm:serve:artifacts npm:serve:media npm:serve:github npm:serve:git npm:serve:notify npm:serve:playwright-runner npm:serve:allure-report npm:serve:codegen npm:serve:playwright",
    "worker": "tsx orchestrator/worker.ts",
    "task": "tsx orchestrator/cli.ts",
    "import:agents": "tsx scripts/import-agents.ts",
    "serve:notify": "tsx mcp-servers/notify/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "file-type": "^22.0.1",
    "image-size": "^2.0.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "tesseract.js": "^6.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.13.9",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
