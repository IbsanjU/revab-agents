# ---- Atlassian auth (shared by Jira / Confluence / JTMF servers) ----
# basic  = Cloud (email + API token)
# bearer = Server / Data Center (Personal Access Token; ATLASSIAN_EMAIL not needed)
ATLASSIAN_AUTH_MODE=basic
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=your-token-here

# ---- Base URLs ----
JIRA_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki

# ---- JTMF / test-management specifics ----
# Custom field id that stores test steps on test issues (org-specific)
JTMF_STEPS_FIELD=customfield_10100
# Issue type names used for tests / test plans in your Jira
JTMF_TEST_ISSUE_TYPE=Test
JTMF_TEST_PLAN_ISSUE_TYPE=Test Plan

# ---- MCP server ports (registered in .vscode/mcp.json) ----
JIRA_MCP_PORT=7311
CONFLUENCE_MCP_PORT=7312
JTMF_MCP_PORT=7313
ARTIFACTS_MCP_PORT=7314
PLAYWRIGHT_RUNNER_MCP_PORT=7316
ALLURE_REPORT_MCP_PORT=7317
CODEGEN_MCP_PORT=7318
MEDIA_MCP_PORT=7319
GITHUB_MCP_PORT=7320
NOTIFY_MCP_PORT=7321

# ---- GitHub search (org/repo code, repo, issue/PR, and commit search) ----
# Personal access token (classic or fine-grained) with at least read access to the
# repos you want searchable. Never commit a real token — this is a local .env only.
GITHUB_TOKEN=your-github-token-here
# Default org to scope searches to when a call doesn't specify org/repo itself
GITHUB_ORG=your-org
# Only needed for GitHub Enterprise Server; leave unset for github.com
GITHUB_API_BASE_URL=

# ---- BrowserStack (only used if detected/configured for a target project — see
#      skills/detect-execution-convention). Never assumed by default. ----
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

# ---- MCP server hardening (optional) ----
# When set, every /mcp request must carry this value in an `x-mcp-secret` header
# (add it under each server's `headers` in .vscode/mcp.json). Servers always bind
# to 127.0.0.1 regardless.
MCP_SHARED_SECRET=

# ---- Notifications (Teams + Outlook email; both optional) ----
# Teams Incoming Webhook / Power Automate workflow URL for notify_teams
TEAMS_WEBHOOK_URL=
# Outlook via Microsoft Graph (app registration with Mail.Send) — preferred
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER=qa-bot@company.com
# Outlook via SMTP (smtp.office365.com) — low-setup fallback when GRAPH_* is unset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Default recipients for worker task-completion emails ({"notify":"email"} payloads)
NOTIFY_EMAIL_TO=

# ---- OCR (media server; optional) ----
# tesseract.js downloads language traineddata once from its CDN and caches it.
# For offline/proxied machines, point these at a local traineddata dir / cache dir.
TESSERACT_LANG_PATH=
TESSERACT_CACHE_PATH=

# ---- Orchestrator ----
WORKER_CONCURRENCY=2
WORKER_POLL_MS=2000
# Per-task timeout (a hung run fails fast); default 30 minutes
WORKER_TASK_TIMEOUT_MS=1800000
